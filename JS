const duckGeometry = new THREE.BoxGeometry(1,1,1);
const duckMaterial = new THREE.MeshStandardMaterial({color:0xffff00});
const duckMesh = new THREE.Mesh(duckGeometry,duckMaterial);
duckMesh.position.set(-5,0,0);
scene.add(duckMesh);

const groundGeo = new THREE.PlaneGeometry(50,10);
const groundMat = new THREE.MeshStandardMaterial({color:0x55aa55});
const ground = new THREE.Mesh(groundGeo,groundMat);
ground.rotation.x = -Math.PI/2;
ground.position.y = -0.5;
scene.add(ground);

// --- Game Variables ---
let obstacles = [];
let velocityY = 0;
const gravity = 0.01; // Defined gravity

// --- Functions ---
function createObstacle(x){
  const geo = new THREE.BoxGeometry(1,1,1);
  const mat = new THREE.MeshStandardMaterial({color:0x8B4513});
  const box = new THREE.Mesh(geo,mat);
  box.position.set(x,0,0);
  scene.add(box);
  obstacles.push(box);
}

// Create an initial obstacle
createObstacle(5);

// --- Input Handling ---
window.addEventListener("keydown",(e)=>{
  // Only jump if on the ground
  if(e.code==="Space" && duckMesh.position.y <= 0){
    velocityY = 0.15;
  }
});

// --- Main Animation Loop ---
function animate(){
  requestAnimationFrame(animate);

  // 1. Duck Movement (Gravity + Jumping)
  velocityY -= gravity;
  duckMesh.position.y += velocityY;

  // Ground collision check
  if(duckMesh.position.y < 0){
    duckMesh.position.y = 0;
    velocityY = 0;
  }

  // 2. Obstacle Movement
  obstacles.forEach(o=>{
    o.position.x -= 0.05; // Slightly faster for gameplay
  });

  // (Optional) Simple obstacle recycling
  if(obstacles.length > 0 && obstacles[0].position.x < -10) {
      obstacles[0].position.x = 10; // Reset to right
  }

  renderer.render(scene,camera);
}
animate(); 
