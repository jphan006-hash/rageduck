
const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
const renderer = new THREE.WebGLRenderer();
renderer.setSize(window.innerWidth, window.innerHeight);
document.body.appendChild(renderer.domElement);
camera.position.z = 10;
camera.position.y = 2;
const light = new THREE.DirectionalLight(0xffffff, 1);
light.position.set(1, 1, 1);
scene.add(light);
scene.add(new THREE.AmbientLight(0x404040));

// --- Objects ---
const duckGeometry = new THREE.BoxGeometry(1, 1, 1);
const duckMaterial = new THREE.MeshStandardMaterial({ color: 0xffff00 });
const duckMesh = new THREE.Mesh(duckGeometry, duckMaterial);
// Positioned higher to visualize falling
duckMesh.position.set(-5, 0, 0); 
scene.add(duckMesh);

const groundGeo = new THREE.PlaneGeometry(50, 10);
const groundMat = new THREE.MeshStandardMaterial({ color: 0x55aa55 });
const ground = new THREE.Mesh(groundGeo, groundMat);
ground.rotation.x = -Math.PI / 2;
ground.position.y = -0.5; // Ground is slightly below 0
scene.add(ground);

// --- Game Variables ---
let obstacles = [];
let velocityY = 0;
const gravity = 0.01; // Acceleration down
const jumpForce = 0.15; // Impulse up
const groundLevel = 0; // The Y position where the ground is

// --- Functions ---
function createObstacle(x) {
    const geo = new THREE.BoxGeometry(1, 1, 1);
    const mat = new THREE.MeshStandardMaterial({ color: 0x8B4513 });
    const box = new THREE.Mesh(geo, mat);
    box.position.set(x, 0, 0); // Position box on the same plane
    scene.add(box);
    obstacles.push(box);
}

// Create initial obstacles
createObstacle(5);
createObstacle(15); // Added another to test loop

// --- Input Handling ---
window.addEventListener("keydown", (e) => {
    // Only jump if on the ground
    if (e.code === "Space" && duckMesh.position.y <= groundLevel) {
        velocityY = jumpForce;
    }
});

// --- Main Animation Loop ---
function animate() {
    requestAnimationFrame(animate);

    // 1. Duck Movement (Gravity + Jumping)
    velocityY -= gravity;
    duckMesh.position.y += velocityY;

    // Corrected Ground collision check
    if (duckMesh.position.y <= groundLevel) {
        duckMesh.position.y = groundLevel; // Stick to ground
        velocityY = 0; // Reset velocity
    }

    // 2. Obstacle Movement
    obstacles.forEach(o => {
        o.position.x -= 0.1; // Increased speed slightly

        // Simple obstacle recycling
        if (o.position.x < -10) {
            o.position.x = 10; // Move back to the right
        }
    });

    renderer.render(scene, camera);
}
animate();
